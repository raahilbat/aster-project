# ─────────────────────────────────────────────────────────────
# Aster Health — environment variables
# Copy this file to .env and fill in your credentials.
# .env is git-ignored and never committed.
# ─────────────────────────────────────────────────────────────

# ── Dexcom Developer API ──────────────────────────────────
# Register at: https://developer.dexcom.com
# Create an app and set the redirect URI to:
#   http://localhost:5173/cgm
#
# Use the SANDBOX credentials while developing.
# Swap to PRODUCTION credentials (same portal) before going live.

# Exposed to the browser — used to build the Dexcom login URL.
# The client ID is not secret; it appears in the OAuth redirect URL.
VITE_DEXCOM_CLIENT_ID=your_sandbox_client_id_here

# Server-only — NEVER expose this to the browser.
# The proxy server (server.js) reads this and adds it to token requests.
DEXCOM_CLIENT_SECRET=your_sandbox_client_secret_here

# ── Optional overrides ────────────────────────────────────
# FRONTEND_ORIGIN=http://localhost:5173   (default)
